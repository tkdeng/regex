package regex

//* Note: this old replace method may still be useful in the future
// it was originally for a PCRE regex engine thhat didnt have a builtin ReplaceFunc method
// the core regex method seems to have better performance

// RepFunc replaces a string with the result of a function
//
// similar to JavaScript .replace(/re/, function(b){})
func (reg *Regexp) RepFunc(buf []byte, rep func(b func(int) []byte) []byte) []byte {
	ind := reg.RE.FindAllIndex(buf, -1)

	res := []byte{}
	trim := 0
	for _, pos := range ind {
		v := buf[pos[0]:pos[1]]
		m := reg.RE.FindSubmatch(v)

		if trim == 0 {
			res = append(res, buf[:pos[0]]...)
		} else {
			res = append(res, buf[trim:pos[0]]...)
		}
		trim = pos[1]

		r := rep(func(g int) []byte {
			if g < 0 || g >= len(m) {
				return []byte{}
			}
			return m[g]
		})

		if r == nil {
			res = append(res, buf[trim:]...)
			return res
		}

		res = append(res, r...)
	}

	res = append(res, buf[trim:]...)
	return res
}
